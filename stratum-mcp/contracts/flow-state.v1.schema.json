{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stratum.regression.io/contracts/flow-state.v1.schema.json",
  "title": "FlowStateResponse",
  "description": "Output of `stratum-mcp query flow <id>` — full flow state.",
  "type": "object",
  "required": ["_schema_version", "flow_id", "flow_name", "status", "current_idx", "round", "rounds_count", "step_count", "ordered_steps", "records"],
  "additionalProperties": false,
  "properties": {
    "_schema_version":  { "type": "string", "const": "1" },
    "flow_id":          { "type": "string" },
    "flow_name":        { "type": "string" },
    "status":           { "type": "string", "enum": ["running", "awaiting_gate", "complete", "killed"] },
    "current_step_id":  { "type": ["string", "null"] },
    "current_idx":      { "type": "integer", "minimum": 0 },
    "round":            { "type": "integer", "minimum": 0 },
    "rounds_count":     { "type": "integer", "minimum": 0 },
    "terminal_status":  { "type": ["string", "null"] },
    "step_count":       { "type": "integer", "minimum": 0 },
    "step_outputs":     { "type": "object" },
    "records":          { "type": "array", "items": { "$ref": "#/$defs/Record" } },
    "rounds":           { "type": "array", "items": { "type": "array" } },
    "ordered_steps":    { "type": "array", "items": { "$ref": "#/$defs/StepSummary" } }
  },
  "$defs": {
    "StepSummary": {
      "type": "object",
      "required": ["id", "function", "mode"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "function": { "type": "string" },
        "mode":     { "type": "string", "enum": ["step", "gate"] }
      }
    },
    "Record": {
      "type": "object",
      "required": ["type", "step_id"],
      "properties": {
        "type":     { "type": "string", "enum": ["step", "gate", "skip"] },
        "step_id":  { "type": "string" }
      }
    }
  }
}
