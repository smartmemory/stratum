{
  "name": "@stratum/ui",
  "version": "0.1.0",
  "description": "React component library for Stratum pipeline monitoring",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "bin"],
  "bin": {
    "stratum-ui": "./bin/serve.js"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.app.config.js",
    "build:lib": "vite build",
    "build:app": "vite build --config vite.app.config.js",
    "dev": "vite"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^6.1.0"
  }
}
